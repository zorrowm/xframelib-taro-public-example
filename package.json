{
  "name": "taian_app",
  "version": "1.0.0",
  "private": true,
  "description": "基于Taro、Vue3和Webpack开发模板",
  "templateInfo": {
    "name": "vue3-NutUI",
    "typescript": true,
    "css": "Sass",
    "framework": "Vue3"
  },
  "scripts": {
    "lint": "eslint --concurrency=3 --fix -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\" ",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "clean": "rimraf components.d.ts pnpm-lock.yaml && rimraf dist"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@nutui/nutui-taro": "^4.3.14",
    "@tarojs/components": "4.2.0",
    "@tarojs/plugin-framework-vue3": "4.2.0",
    "@tarojs/plugin-html": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "xframelib-taro": "^0.1.9"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@iconify/tools": "^5.0.11",
    "@iconify/utils": "^3.1.3",
    "@eslint/js": "^9.38.0",
    "@nutui/auto-import-resolver": "^1.0.0",
    "@tarojs/cli": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@unocss/preset-icons": "^66.5.4",
    "@vue/babel-plugin-jsx": "^2.0.1",
    "@vue/compiler-sfc": "^3.5.34",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "babel-preset-taro": "4.2.0",
    "css-loader": "7.1.4",
    "eslint": "^10.4.0",
    "eslint-config-taro": "4.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "jsdom-global": "^3.0.2",
    "jsdom-polyfill": "^0.1.0",
    "postcss": "^8.5.14",
    "rimraf": "^6.1.3",
    "style-loader": "4.0.0",
    "stylelint": "^17.11.1",
    "svg-url-loader": "^8.0.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.2",
    "unocss": "^66.5.4",
    "unocss-applet": "^0.12.2",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-vue-components": "^29.2.0",
    "vue-loader": "^17.4.2",
    "webpack": "5.104.1",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
